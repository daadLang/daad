# Test all operators
# Comparison
賳鬲賷噩丞1 = 5 == 5
賳鬲賷噩丞2 = 10 != 5
賳鬲賷噩丞3 = 7 < 10
賳鬲賷噩丞4 = 15 > 10
賳鬲賷噩丞5 = 5 <= 5
賳鬲賷噩丞6 = 20 >= 15

# Logical
氐丨賷丨 賵 禺胤兀
氐丨賷丨 丕賵 禺胤兀
賱賷爻 氐丨賷丨

# Bitwise
賯賷賲丞1 = 5 & 3
賯賷賲丞2 = 5 | 3
賯賷賲丞3 = 5 ^ 3
賯賷賲丞4 = ~5
賯賷賲丞5 = 2 << 3
賯賷賲丞6 = 16 >> 2

# Assignment
毓丿丿 = 10
毓丿丿 += 5
毓丿丿 -= 3
毓丿丿 *= 2
毓丿丿 /= 4
毓丿丿 %= 3
毓丿丿 **= 2
